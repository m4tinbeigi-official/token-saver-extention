{
  "name": "tokensaver-desktop",
  "productName": "Token Saver",
  "version": "1.0.0",
  "description": "بهینه‌سازی مصرف توکن AI Coding Agents با یک کلیک — برای ویندوز و مک",
  "main": "main.js",
  "author": "Token Saver",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "test": "node test-engine.js",
    "dist": "electron-builder",
    "dist:win": "electron-builder --win",
    "dist:mac": "electron-builder --mac"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "ir.tokensaver.desktop",
    "productName": "Token Saver",
    "files": [
      "main.js",
      "preload.js",
      "config-engine.js",
      "src/**/*"
    ],
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "win": {
      "icon": "build/icon.ico",
      "target": [
        { "target": "nsis", "arch": ["x64"] }
      ],
      "artifactName": "TokenSaver-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerHeaderIcon": "build/icon.ico",
      "shortcutName": "Token Saver",
      "createDesktopShortcut": true
    },
    "mac": {
      "icon": "build/icon.icns",
      "target": [
        { "target": "dmg", "arch": ["x64", "arm64"] }
      ],
      "category": "public.app-category.developer-tools",
      "artifactName": "TokenSaver-${version}-${arch}.${ext}",
      "darkModeSupport": true,
      "hardenedRuntime": false,
      "gatekeeperAssess": false
    },
    "dmg": {
      "icon": "build/icon.icns",
      "background": "build/dmg-background.png",
      "iconSize": 120,
      "window": { "width": 660, "height": 420 },
      "contents": [
        { "x": 180, "y": 210, "type": "file" },
        { "x": 480, "y": 210, "type": "link", "path": "/Applications" }
      ]
    }
  }
}
